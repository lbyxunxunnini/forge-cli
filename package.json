{
  "name": "forge-cli",
  "version": "1.0.0",
  "description": "通用 AI 协作 CLI Agent - 支持多模型、多语言、多工具",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "forge": "dist/main.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lbyxunxunnini/forge-cli.git"
  },
  "keywords": [
    "ai",
    "cli",
    "agent",
    "claude",
    "llm",
    "multi-model"
  ],
  "author": "lbyxunxunnini",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lbyxunxunnini/forge-cli/issues"
  },
  "homepage": "https://github.com/lbyxunxunnini/forge-cli#readme",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "ai": "^6.0.191",
    "axios": "^1.17.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.2.0",
    "cosmiconfig": "^9.0.0",
    "openai": "^4.0.0",
    "ora": "^8.0.0",
    "readline": "^1.3.0",
    "yaml": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.8"
  }
}
